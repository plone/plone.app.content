<div i18n:domain="plone">
  <div class="mb-2">
    <label class="form-label" i18n:translate="tags_to_remove">Tags to remove</label>
    <select multiple class="toremove pat-select2" name="toremove" style="width:100%">
      <% var tags = [];
      _.each(items, function(item, index) {
        _.each(item.Subject, function(tag) {
          if(tags.indexOf(tag) === -1){
            tags.push(tag);
            %><option value="<%- tag %>"><%- tag %></option>
            <%
          }
        });
      }); %>
    </select>
  </div>

  <div>
    <label class="form-label" i18n:translate="tags_to_add">Tags to add</label>
    <input class="toadd pat-select2" name="toadd" style="width:100%"
           data-pat-select2="multiple: true; vocabularyUrl: ${python: options['vocabulary_url']}"/>

  </div>

  <div class="form-check">
    <input class="form-check-input" type="checkbox" name="recurse" value="yes" id="fcCheckRecurse" />
    <label class="form-check-label" for="fcCheckRecurse" i18n:translate="label_include_contained_objects">Include contained items</label>
    <p class="form-text" i18n:translate="help_include_contained_objects">
    If checked, this will attempt to modify the status of all content in any selected folders and their subfolders.
    </p>
  </div>

</div>
